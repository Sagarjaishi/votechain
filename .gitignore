# ===============================
# VoteChain .gitignore
# ===============================

# Node modules
node_modules/
**/node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build folders
dist/
build/
out/

# Vite cache
.vite/

# Coverage / test reports
coverage/
.nyc_output/

# OS files
.DS_Store
Thumbs.db

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.temp

# ===============================
# Hardhat / Blockchain
# ===============================

# Hardhat generated folders
blockchain/cache/
blockchain/artifacts/
cache/
artifacts/

# Local blockchain data (if used)
*.db

# Secret keys / wallet files
secrets.json
mnemonic.txt
privatekey.txt

# ===============================
# Frontend
# ===============================

client/dist/
client/.vite/

# ===============================
# Backend
# ===============================

server/logs/
server/uploads/

# ===============================
# Misc
# ===============================

*.zip
*.rar
*.7z